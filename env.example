import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { ArrowLeft, BookOpen, Clock, Tag, ChevronRight, Share2 } from 'lucide-react';
import { BLOG_POSTS, BlogPost } from '../constants/blogData';

export const Blog: React.FC<{ onBack: () => void }> = ({ onBack }) => {
  const [selectedPost, setSelectedPost] = useState<BlogPost | null>(null);

  return (
    <div className="max-w-4xl mx-auto px-4 py-12">
      <button
        onClick={selectedPost ? () => setSelectedPost(null) : onBack}
        className="flex items-center gap-2 text-sm font-bold text-txt-muted hover:text-ink transition-colors mb-8 uppercase tracking-widest"
      >
        <ArrowLeft size={16} />
        {selectedPost ? 'Back to Blog' : 'Back to Home'}
      </button>

      <AnimatePresence mode="wait">
        {!selectedPost ? (
          <motion.div
            key="list"
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -20 }}
            className="space-y-12"
          >
            <div className="text-center mb-16">
              <h2 className="text-5xl md:text-7xl font-display font-black text-ink mb-4 tracking-tight">
                Business Growth Insights
              </h2>
              <p className="text-lg md:text-xl text-txt-secondary max-w-2xl mx-auto font-body">
                Practical advice and local strategies to help your Montgomery business thrive.
              </p>
            </div>

            <div className="grid gap-8">
              {BLOG_POSTS.map((post) => (
                <motion.article
                  key={post.id}
                  whileHover={{ y: -4 }}
                  className="bg-paper rounded-3xl border border-border-mgm overflow-hidden flex flex-col md:flex-row group cursor-pointer"
                  onClick={() => setSelectedPost(post)}
                >
                  <div className="md:w-1/3 h-48 md:h-auto relative overflow-hidden">
                    <img
                      src={post.image}
                      alt={post.title}
                      className="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                      referrerPolicy="no-referrer"
                    />
                    <div className="absolute top-4 left-4">
                      <span className="bg-ink text-paper text-sm font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                        {post.category}
                      </span>
                    </div>
                  </div>
                  <div className="p-8 md:w-2/3 flex flex-col justify-center">
                    <div className="flex items-center gap-4 text-sm text-txt-muted mb-3 font-medium">
                      <span className="flex items-center gap-1">
                        <Clock size={14} /> {post.readTime}
                      </span>
                      <span>•</span>
                      <span>{post.date}</span>
                    </div>
                    <h3 className="text-xl font-display font-bold text-ink mb-3 group-hover:text-ember transition-colors">
                      {post.title}
                    </h3>
                    <p className="text-sm text-txt-secondary mb-6 line-clamp-2 font-body leading-relaxed">
                      {post.excerpt}
                    </p>
                    <div className="flex items-center gap-2 text-sm font-bold text-ember uppercase tracking-widest">
                      Read Article <ChevronRight size={16} />
                    </div>
                  </div>
                </motion.article>
              ))}
            </div>
          </motion.div>
        ) : (
          <motion.div
            key="post"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="bg-paper rounded-[40px] border border-border-mgm overflow-hidden"
          >
            <div className="h-[400px] relative">
              <img
                src={selectedPost.image}
                alt={selectedPost.title}
                className="w-full h-full object-cover"
                referrerPolicy="no-referrer"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/20 to-transparent" />
              <div className="absolute bottom-12 left-12 right-12">
                <div className="flex items-center gap-3 mb-4">
                  <span className="bg-ember text-paper text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-widest">
                    {selectedPost.category}
                  </span>
                  <span className="text-paper/80 text-sm font-medium flex items-center gap-1.5">
                    <Clock size={14} /> {selectedPost.readTime}
                  </span>
                </div>
                <h1 className="text-4xl md:text-5xl font-display font-black text-paper tracking-tight leading-tight">
                  {selectedPost.title}
                </h1>
              </div>
            </div>
            
            <div className="p-12">
              <div className="flex items-center justify-between mb-10 pb-6 border-b border-border-mgm/30">
                <div className="flex items-center gap-4">
                  <div className="w-12 h-12 bg-border-mgm rounded-full flex items-center justify-center text-ink font-bold">
                    LM
                  </div>
                  <div>
                    <p className="text-sm font-bold text-ink">LaunchMGM Team</p>
                    <p className="text-sm text-txt-muted">{selectedPost.date}</p>
                  </div>
                </div>
                <button className="p-3 bg-surface rounded-full text-txt-muted hover:text-ember transition-colors border border-border-mgm/50">
                  <Share2 size={20} />
                </button>
              </div>

              <div className="prose prose-lg max-w-none">
                {selectedPost.content.split('\n').map((paragraph, idx) => (
                  <p key={idx} className="text-lg text-txt-secondary leading-relaxed mb-6 font-body">
                    {paragraph.trim()}
                  </p>
                ))}
              </div>

              <div className="mt-12 pt-12 border-t border-border-mgm/30">
                <h4 className="text-sm font-bold text-ink uppercase tracking-widest mb-6">Related Topics</h4>
                <div className="flex flex-wrap gap-2">
                  {['Entrepreneurship', 'Montgomery', 'Local Business', 'Strategy'].map(tag => (
                    <span key={tag} className="flex items-center gap-1.5 px-4 py-2 bg-surface rounded-full text-sm text-txt-secondary font-medium border border-border-mgm/30">
                      <Tag size={14} className="text-txt-muted" />
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
};
